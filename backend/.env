# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================

NODE_ENV=production
PORT=3000

# ============================================
# AFFILIATE CONFIGURATION
# ============================================
AFFILIATE_CODE=0rfpRaHuZeFMjdsyM5hasGNd7ZgqdRLk

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=https://digitmatchstars-two.vercel.app/

# Additional CORS origins (comma-separated for multiple domains)
CORS_ORIGINS=https://digitmatchstars-two.vercel.app,https://digitmatchstar.com,https://www.digitmatchstar.com

# ============================================
# DERIV OAUTH CONFIGURATION
# ============================================

# Deriv App Client ID
DERIV_CLIENT_ID=33rp9Oy3CuZ2io6XAuLZ6

# OAuth Redirect URI (must match exactly what's in Deriv Dashboard)
OAUTH_REDIRECT_URI=https://www.digitmatchstar.com/index.html

# Deriv OAuth Endpoints
DERIV_AUTH_URL=https://auth.deriv.com/oauth2/auth
DERIV_TOKEN_URL=https://auth.deriv.com/oauth2/token

# OAuth Scopes (space-separated)
OAUTH_SCOPES=read trade account_manage

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Bot page filename
BOT_PAGE=bot-obfuscated.html

# Landing page filename
LANDING_PAGE=index.html

# ============================================
# SECURITY (Add these in Vercel dashboard)
# ============================================

# JWT Secret for token signing (generate a random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Encryption key for sensitive data (generate a random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key_here

# Session secret for express-session (if used)
SESSION_SECRET=your_session_secret_here

# ============================================
# RATE LIMITING (Optional)
# ============================================

# Rate limit window (minutes)
RATE_LIMIT_WINDOW=15

# Rate limit max requests per window
RATE_LIMIT_MAX=100

# ============================================
# LOGGING (Optional)
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable request logging
ENABLE_REQUEST_LOGGING=true
